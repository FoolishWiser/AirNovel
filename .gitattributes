# ─── Auto detect text files and normalize to LF ──
* text=auto

# ─── Source code: always LF ──────────────────────
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
*.bat       text eol=crlf

# ─── Binary files: never diff/merge ──────────────
*.apk       binary
*.aab       binary
*.jar       binary
*.aar       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.keystore  binary
*.db        binary
*.ttf       binary
*.otf       binary

# ─── Git LFS: no LFS needed for this project ─────
# All text files are small; LFS not required
